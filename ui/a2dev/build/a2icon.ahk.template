#Include <path>
#Include <theme>
#Include <windows>

class {class_name} {{
    static _cache := Map()
    static _base := path_dirname(A_LineFile, 4) "\theme\"
    static _last_theme := ""

    static __Get(name, params) {{
        theme_name := theme_get()
        if {class_name}._last_theme != theme_name {{
            {class_name}._cache := Map()
            {class_name}._last_theme := theme_name
        }}
        if {class_name}._cache.Has(name)
            return {class_name}._cache[name]

        path := {class_name}._base name ".ico"
        if !FileExist(path) {{
            path := {class_name}._base theme_name "\" name ".ico"
            if !FileExist(path)
                path := {class_name}._base "a2.ico"
        }}
        {class_name}._cache[name] := path
        return path
    }}

